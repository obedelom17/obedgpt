# Groq API Keys (2-3 clés séparées par des virgules pour la rotation)
# Chaque clé = 1 compte Groq (20 req/min, ~288k tokens/jour)
GROQ_API_KEYS=gsk_votre_cle_1,gsk_votre_cle_2,gsk_votre_cle_3

# Gemini API Keys (2-3 clés séparées par des virgules pour la rotation)
# IMPORTANT : Chaque clé doit venir d'un PROJET Google Cloud DIFFERENT
# pour avoir des quotas séparés (250 req/jour par projet)
GEMINI_API_KEYS=AIza_projet_1,AIza_projet_2,AIza_projet_3
